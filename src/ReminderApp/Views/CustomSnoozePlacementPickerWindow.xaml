<Window x:Class="ReminderApp.Views.CustomSnoozePlacementPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор позиции окна отложения"
        Width="420"
        Height="240"
        MinWidth="380"
        MinHeight="220"
        WindowStyle="ToolWindow"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        WindowStartupLocation="Manual">
    <Border Margin="10"
            Padding="12"
            CornerRadius="10"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Перетащите окно в нужное место"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Text="Это примерное окно отложения. Перетащите его, затем нажмите кнопку ниже."
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"/>
            <Button Grid.Row="2"
                    Margin="0,12,0,0"
                    Content="Использовать это место"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="UseButton_OnClick"/>
        </Grid>
    </Border>
</Window>
