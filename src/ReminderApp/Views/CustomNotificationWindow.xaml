<Window x:Class="ReminderApp.Views.CustomNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="360"
        SizeToContent="Height"
        MinHeight="96"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Storyboard x:Key="IntroStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="18" To="0" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="X"
                             From="14" To="0" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="OutroStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="12" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ProgressStoryboard">
            <DoubleAnimation Storyboard.TargetName="ProgressScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0" To="1"/>
        </Storyboard>
    </Window.Resources>
    <Border x:Name="RootBorder"
            Opacity="0"
            Margin="12"
            CornerRadius="12"
            Background="{DynamicResource NotificationCardBackgroundBrush}"
            BorderBrush="{DynamicResource NotificationCardBorderBrush}"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Direction="270"
                              Opacity="0.22"
                              Color="{DynamicResource DropShadowColor}"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform"/>
        </Border.RenderTransform>
        <Grid Margin="14,12,12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.RowSpan="2"
                    Width="40"
                    Height="40"
                    CornerRadius="20"
                    Background="{DynamicResource NotificationIconBgBrush}"
                    BorderBrush="{DynamicResource NotificationIconBorderBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Top"
                    Margin="0,2,12,0">
                <Image Width="28"
                       Height="28"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"
                       Source="pack://application:,,,/Assets/reminder_icon_32.png"/>
            </Border>

            <TextBlock Grid.Column="1"
                       Text="{Binding TitleText}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="{DynamicResource NotificationTitleBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,8,4"/>

            <Button Grid.Column="2"
                    Content="&#x00D7;"
                    Width="26"
                    Height="26"
                    Padding="0"
                    FontSize="16"
                    FontWeight="Normal"
                    Foreground="{DynamicResource NotificationCloseForegroundBrush}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Top"
                    Click="CloseButton_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource NotificationCloseHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Grid.ColumnSpan="2"
                       Text="{Binding MessageText}"
                       FontSize="13"
                       Foreground="{DynamicResource NotificationMessageBrush}"
                       TextWrapping="Wrap"
                       LineHeight="18"/>

            <StackPanel x:Name="ActionsPanel"
                        Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0"
                        Visibility="Collapsed">
                <Button x:Name="DoneButton"
                        Content="✓"
                        Width="34"
                        Height="34"
                        Margin="0,0,8,0"
                        Padding="0"
                        FontSize="18"
                        ToolTip="Выполнено"
                        Cursor="Hand"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource ButtonTextBrush}"
                        BorderThickness="0"
                        Click="Done_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <WrapPanel x:Name="SnoozeButtonsPanel" Orientation="Horizontal"/>
                <Button x:Name="CustomSnoozeToggleButton"
                        Content="…"
                        Margin="0,0,0,4"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        Background="{DynamicResource NotificationSecondaryButtonBgBrush}"
                        Foreground="{DynamicResource NotificationSecondaryButtonFgBrush}"
                        BorderBrush="{DynamicResource NotificationSecondaryButtonBorderBrush}"
                        BorderThickness="1"
                        Click="CustomSnoozeToggleButton_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource NotificationCloseHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <Border x:Name="ProgressRow"
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Height="3"
                    CornerRadius="1.5"
                    Background="{DynamicResource ProgressTrackBrush}"
                    Margin="0,12,0,0"
                    ClipToBounds="True">
                <Border Background="{DynamicResource ProgressFillBrush}"
                        HorizontalAlignment="Left"
                        CornerRadius="1.5"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="0" ScaleY="1"/>
                    </Border.RenderTransform>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
