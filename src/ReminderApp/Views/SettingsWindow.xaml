<Window x:Class="ReminderApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ReminderApp.Helpers"
        Title="Настройки"
        Icon="pack://application:,,,/Assets/reminder_icon.ico"
        MinWidth="720"
        MinHeight="520"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="SettingsWindow_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVis"/>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="24,20,24,12">
            <TextBlock Text="Настройки" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="Файлы лежат рядом с программой. После ручного редактирования перезапустите приложение."
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"/>
            <TextBlock Text="Изменения применяются после сохранения."
                       FontSize="12"
                       Foreground="{DynamicResource HintTextBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="24,0,24,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Внешний вид" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Тема приложения" Style="{StaticResource SettingLabel}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="HelpTheme" Content="?" Style="{StaticResource HelpIconToggleStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                        <ComboBox x:Name="ThemeComboBox"
                                  MinWidth="200"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding ThemeModeItems}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"/>
                        <TextBlock Text="Авто — программа сама выбирает светлую или тёмную тему, как в Windows. Светлая и Тёмная фиксируют выбранный вариант."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="{Binding IsChecked, ElementName=HelpTheme, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Уведомления" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Content="Звук при уведомлениях" IsChecked="{Binding PlayNotificationSound, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="HelpSound" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Если включено, при напоминании будет короткий звук."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Visibility="{Binding IsChecked, ElementName=HelpSound, Converter={StaticResource BoolToVis}}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Длительность обычного уведомления (с)" Style="{StaticResource SettingLabel}"/>
                            <ToggleButton x:Name="HelpNotifDur" Grid.Row="0" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" Margin="8,0,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Slider Minimum="2" Maximum="30" Width="180" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding NotificationDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{Binding NotificationDurationSeconds}" Style="{StaticResource SettingValueText}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Сколько секунд маленькое уведомление остаётся на экране (от 2 до 30)."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Visibility="{Binding IsChecked, ElementName=HelpNotifDur, Converter={StaticResource BoolToVis}}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Автоотложение при закрытии уведомления (мин)" Style="{StaticResource SettingLabel}"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Slider Minimum="1" Maximum="1440" Width="220" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding AutoSnoozeOnDismissMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{Binding AutoSnoozeOnDismissMinutes}" Style="{StaticResource SettingValueText}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Позиция уведомлений" Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="PlacementComboBox"
                                      Grid.Column="1"
                                      Width="220"
                                      ItemsSource="{Binding PlacementModeItems}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedPlacement, Mode=TwoWay}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Выбрать место уведомления"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="PickNotificationPlacement_OnClick"/>
                            <Button Content="Сбросить место"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ResetNotificationPlacement_OnClick"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Максимум уведомлений на экране" Style="{StaticResource SettingLabel}"/>
                            <ToggleButton x:Name="HelpMaxNotif" Grid.Row="0" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" Margin="8,0,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Slider Minimum="1" Maximum="8" Width="180" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding MaxVisibleNotifications, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{Binding MaxVisibleNotifications}" Style="{StaticResource SettingValueText}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="Показывать уведомление после создания напоминания"
                                      IsChecked="{Binding ShowCreatedNotification, Mode=TwoWay}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <ToggleButton x:Name="HelpCreatedNotif" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Если выключено, после добавления напоминания всплывашка «создано» не показывается."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                                   Visibility="{Binding IsChecked, ElementName=HelpCreatedNotif, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Отложить напоминание" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <ToggleButton x:Name="HelpSnooze" Content="?" Style="{StaticResource HelpIconToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,2"/>
                        </Grid>
                        <TextBlock Text="Укажите минуты и включите нужные кнопки (1..1440):" Margin="0,0,0,8" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <StackPanel Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox Content="Быстрое отложение #1" IsChecked="{Binding Snooze1Enabled, Mode=TwoWay}" Width="180"/>
                                <TextBox x:Name="Snooze1TextBox" Width="80" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding Snooze1Text, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox Content="Быстрое отложение #2" IsChecked="{Binding Snooze2Enabled, Mode=TwoWay}" Width="180"/>
                                <TextBox x:Name="Snooze2TextBox" Width="80" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding Snooze2Text, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox Content="Быстрое отложение #3" IsChecked="{Binding Snooze3Enabled, Mode=TwoWay}" Width="180"/>
                                <TextBox x:Name="Snooze3TextBox" Width="80" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding Snooze3Text, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <CheckBox Content="Другой срок…" IsChecked="{Binding CustomSnoozeEnabled, Mode=TwoWay}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SnoozeError}" Foreground="{DynamicResource ErrorTextBrush}" TextWrapping="Wrap" Margin="0,0,0,6"
                                   Visibility="{Binding SnoozeError, Converter={StaticResource NonEmptyToVis}}"/>
                        <TextBlock Text="Эти кнопки появляются, когда срабатывает напоминание. Можно быстро отложить на выбранное время."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Visibility="{Binding IsChecked, ElementName=HelpSnooze, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Окно отложения" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Позиция окна «Отложить напоминание»" Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="SnoozeWindowPlacementComboBox"
                                      Grid.Column="1"
                                      Width="220"
                                      ItemsSource="{Binding SnoozeWindowPlacementModeItems}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedSnoozeWindowPlacement, Mode=TwoWay}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Выбрать место"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="PickCustomSnoozePlacement_OnClick"/>
                            <Button Content="Сбросить место"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ResetCustomSnoozePlacement_OnClick"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Поведение окна и ввода" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" Content="Добавлять напоминание по клавише Enter" IsChecked="{Binding SubmitReminderOnEnter, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="HelpEnter" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Если включено, можно написать текст и нажать Enter. Если выключено — только кнопка «Добавить»."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Visibility="{Binding IsChecked, ElementName=HelpEnter, Converter={StaticResource BoolToVis}}"/>
                        <CheckBox Content="При запуске сразу ставить курсор в поле ввода" IsChecked="{Binding AutoFocusInputOnStart, Mode=TwoWay}" Margin="0,0,0,6"/>
                        <CheckBox Content="Показывать примеры фраз под полем ввода" IsChecked="{Binding ShowInputExamples, Mode=TwoWay}" Margin="0,0,0,6"/>
                        <CheckBox Content="Крестик окна сворачивает в трей (а не закрывает программу)" IsChecked="{Binding MinimizeToTrayOnClose, Mode=TwoWay}" Margin="0,0,0,6"/>
                        <CheckBox Content="Один раз за запуск напоминать, что программа в трее" IsChecked="{Binding ShowTrayNoticeOncePerSession, Mode=TwoWay}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Интервал проверки напоминаний (с)" Style="{StaticResource SettingLabel}"/>
                            <ToggleButton x:Name="HelpScheduler" Grid.Row="0" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" Margin="8,0,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Slider Minimum="1" Maximum="60" Width="180" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding SchedulerIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{Binding SchedulerIntervalSeconds}" Style="{StaticResource SettingValueText}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Обычно менять интервал не нужно." FontSize="12" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="Как часто программа проверяет, не пора ли показать напоминание. Слишком редко — задержка, слишком часто — лишняя нагрузка."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                                   Visibility="{Binding IsChecked, ElementName=HelpScheduler, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Автозапуск" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="Запускать SimpleReminder вместе с Windows"
                                      IsChecked="{Binding AutoStartWithWindows, Mode=TwoWay}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <ToggleButton x:Name="HelpAutoStart" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Если включить, программа будет запускаться сама после входа в Windows. Это удобно, чтобы напоминания работали без ручного запуска."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Visibility="{Binding IsChecked, ElementName=HelpAutoStart, Converter={StaticResource BoolToVis}}"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="При автозапуске сворачивать в трей"
                                      IsChecked="{Binding StartMinimizedOnAutoStart, Mode=TwoWay}"
                                      IsEnabled="{Binding StartMinimizedOnAutoStartEnabled}"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                            <ToggleButton x:Name="HelpAutoTray" Grid.Column="1" Content="?" Style="{StaticResource HelpIconToggleStyle}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Если включить, при автозапуске главное окно не будет появляться на экране. Программа тихо запустится и будет ждать в трее рядом с часами."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Visibility="{Binding IsChecked, ElementName=HelpAutoTray, Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="Если вы перенесли папку программы в другое место, выключите и снова включите автозапуск."
                                   FontSize="12"
                                   Foreground="{DynamicResource HintTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Папка с данными" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <ToggleButton x:Name="HelpDataFolder" Content="?" Style="{StaticResource HelpIconToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,2"/>
                        </Grid>
                        <TextBlock Text="Программа хранит напоминания и настройки рядом с SimpleReminder.exe в папке data. Чтобы перенести на другой компьютер, скопируйте всю папку программы целиком."
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                                   Visibility="{Binding IsChecked, ElementName=HelpDataFolder, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="О программе" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="AboutVersion" FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource FooterBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        MinWidth="100"
                        IsCancel="True"
                        Click="Cancel_OnClick"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Content="Сохранить"
                        MinWidth="120"
                        Margin="10,0,0,0"
                        IsDefault="True"
                        Click="Save_OnClick"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
