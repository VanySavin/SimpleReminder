<Window x:Class="ReminderApp.Views.CustomSnoozeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ReminderApp.Helpers"
        Title="Отложить напоминание"
        Icon="pack://application:,,,/Assets/reminder_icon.ico"
        MinWidth="380"
        MinHeight="220"
        Width="420"
        Height="240"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="CustomSnoozeWindow_OnPreviewKeyDown">
    <Window.Resources>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyToHintVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Border Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Отложить напоминание" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="ReminderTextBlock"
                           Grid.Row="1"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           MaxHeight="56"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"/>
                <TextBlock Grid.Row="2"
                           Margin="0,8,0,0"
                           Text="Напишите, на когда отложить"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="13"/>
                <Grid Grid.Row="3" Margin="0,8,0,0" MinHeight="40">
                    <TextBox x:Name="SnoozeInputTextBox"
                             Style="{StaticResource PrimaryInputTextBoxStyle}"
                             TextChanged="SnoozeInputTextBox_OnTextChanged"
                             Text=""/>
                    <TextBlock Text="на 5 минут, завтра в 10, через месяц"
                               Margin="14,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource HintTextBrush}"
                               FontSize="12"
                               IsHitTestVisible="False"
                               Visibility="{Binding Text, ElementName=SnoozeInputTextBox, Converter={StaticResource EmptyToHintVis}}"/>
                </Grid>
                <TextBlock x:Name="ErrorTextBlock"
                           Grid.Row="4"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource WarningBrush}"
                           FontSize="12"
                           Visibility="Collapsed"/>
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Отмена"
                            MinWidth="90"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelButton_OnClick"/>
                    <Button Content="Отложить"
                            MinWidth="110"
                            Margin="8,0,0,0"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SnoozeButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
