<Window x:Class="ReminderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:ReminderApp.Helpers"
        xmlns:models="clr-namespace:ReminderApp.Models"
        mc:Ignorable="d"
        Title="SimpleReminder"
        Icon="pack://application:,,,/Assets/reminder_icon.ico"
        MinHeight="520"
        MinWidth="720"
        SizeToContent="Manual"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyToHintVis"/>
        <helpers:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="24,12,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Напоминания"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="О программе"
                            Padding="14,8"
                            FontSize="14"
                            Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenAboutCommand}"/>
                    <Button Content="Настройки"
                            Padding="14,8"
                            FontSize="14"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="Локальные напоминания на этом компьютере"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="24,8,24,0" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Новое напоминание"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,8"/>

                <Grid MinHeight="56" MaxHeight="64" Margin="0,0,0,6">
                    <TextBox x:Name="InputBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PrimaryInputTextBoxStyle}"
                             AcceptsReturn="False"
                             PreviewKeyDown="InputBox_OnPreviewKeyDown"/>
                    <TextBlock Text="Например: через 20 минут, завтра суп или через месяц"
                               Margin="14,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource HintTextBrush}"
                               FontSize="13"
                               IsHitTestVisible="False"
                               Visibility="{Binding Text, ElementName=InputBox, Converter={StaticResource EmptyToHintVis}}"/>
                </Grid>
                <TextBlock Text="{Binding InputExamplesText}"
                           FontSize="12"
                           Foreground="{DynamicResource HintTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"
                           Visibility="{Binding ShowInputExamplesLine, Converter={StaticResource BoolToVis}}"/>

                <TextBlock Text="{Binding ParseError}"
                           Margin="0,0,0,6"
                           FontSize="13"
                           Foreground="{DynamicResource ErrorTextBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ParseError, Converter={StaticResource NonEmptyToVis}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Тест уведомления"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,10,0"
                            Command="{Binding TestNotificationCommand}"/>
                    <Button Content="Добавить"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddReminderCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Активные напоминания"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="24,10,24,6"/>

        <Border Grid.Row="3"
                Margin="24,0,24,6"
                Style="{StaticResource CardBorder}"
                MinHeight="160"
                Padding="10">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasActiveReminders, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ActiveReminders}"
                                  Padding="0,0,4,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12,10"
                                        Background="{DynamicResource ListRowBackgroundBrush}"
                                        BorderBrush="{DynamicResource ListRowBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding StatusLine}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFiredPending}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SubStatusLine}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding SubStatusLine, Converter={StaticResource NonEmptyToVis}}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ListRowTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,10,0"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ItemsControl ItemsSource="{Binding SnoozeSlots}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:SnoozeSlotRow}">
                                                        <Button Content="{Binding Label}"
                                                                Style="{StaticResource ListActionButton}"
                                                                Margin="0,0,6,4"
                                                                Command="{Binding DataContext.SnoozeForSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="Выполнено"
                                                    Style="{StaticResource ListActionButton}"
                                                    Margin="4,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.MarkDoneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="…"
                                                    ToolTip="Другой срок"
                                                    Style="{StaticResource ListActionButton}"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.CustomSnoozeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Удалить"
                                                    Style="{StaticResource ListActionButton}"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="12"
                            Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Пока напоминаний нет"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource EmptyStateTitleBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Создайте первое напоминание обычными словами"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource HintTextBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="340"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4"
                   Margin="24,0,24,12"
                   FontSize="13"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>
